{
  "name": "whatsapp-bot-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend independiente para Dealerbot AI con Baileys y Supabase",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --ignore '../../auth_info_baileys/**' --ignore '*.json' index.js",
    "cleanup": "node cleanup.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@supabase/supabase-js": "^2.39.0",
