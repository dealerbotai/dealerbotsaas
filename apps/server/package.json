    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemon": "^3.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.40.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.7.2",
    "stripe": "^22.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "zod": "^3.24.3"
  }
